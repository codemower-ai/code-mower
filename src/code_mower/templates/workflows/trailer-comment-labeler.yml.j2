# Code Mower workflow template: apply labels from trusted audit-result comments.
name: __WORKFLOW_NAME__

on:
  issue_comment:
    types: [created]
  workflow_dispatch:
    inputs:
      lane:
        description: "Trailer-comment lane to classify"
        required: false
        default: "__TRAILER_LANE__"

permissions:
  contents: read
  issues: write
  pull-requests: read

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: "true"

jobs:
  label:
    if: >-
      github.event_name == 'workflow_dispatch' ||
      (
        github.event_name == 'issue_comment' &&
        github.event.issue.pull_request &&
        (
          contains(github.event.comment.body, '__TRAILER_PREFIX__') ||
          contains(github.event.comment.body, '__DISPLAY_NAME__ Audit') ||
          contains(github.event.comment.body, 'HEAD_CHANGED_DURING_REVIEW') ||
          contains(github.event.comment.body, 'Label state:') ||
          contains(github.event.comment.body, 'Intended label state:') ||
          contains(github.event.comment.body, 'Expected labels:') ||
          contains(github.event.comment.body, 'Intended labels:') ||
          contains(github.event.comment.body, '__NEEDS_LABEL__') ||
          contains(github.event.comment.body, '__DONE_LABEL__') ||
          contains(github.event.comment.body, '__BLOCKED_LABEL__')
        )
      )
    runs-on: ubuntu-latest
    timeout-minutes: 5
    steps:
      - name: Check out Code Mower support files from default branch
        uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10
        with:
          ref: {% raw %}${{ github.event.repository.default_branch }}{% endraw %}
          persist-credentials: false

      - name: Apply __DISPLAY_NAME__ audit labels
        env:
          GITHUB_TOKEN: {% raw %}${{ github.token }}{% endraw %}
          __LABEL_TOKEN_ENV__: {% raw %}${{ secrets.__LABEL_TOKEN_ENV__ }}{% endraw %}
          __AUTHORS_ENV__: {% raw %}${{ vars.__AUTHORS_ENV__ }}{% endraw %}
          TRAILER_LANE: {% raw %}${{ github.event.inputs.lane || '__TRAILER_LANE__' }}{% endraw %}
        run: tools/code_mower trailer-comment-labeler --lane "${TRAILER_LANE}"
