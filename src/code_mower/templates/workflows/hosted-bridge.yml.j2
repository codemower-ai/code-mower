# Code Mower workflow template: manually requeue a hosted reviewer lane.
#
# Hosted provider apps own the actual review session. This bridge gives
# maintainers a cheap, auditable way to re-add the lane's needs label and, when
# an expected head SHA is supplied, refuse to queue against an unexpected head.
name: __WORKFLOW_NAME__

on:
  workflow_dispatch:
    inputs:
      pr_number:
        description: "Pull request number to requeue"
        required: true
      head_sha:
        description: "Optional expected current PR head SHA"
        required: false

permissions:
  contents: read
  issues: write
  pull-requests: read

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: "true"

jobs:
  requeue:
    runs-on: ubuntu-latest
    timeout-minutes: 5
    steps:
      - name: Requeue __DISPLAY_NAME__ hosted review
        env:
          GH_TOKEN: {% raw %}${{ secrets.__LABEL_TOKEN_ENV__ || github.token }}{% endraw %}
          PR_NUMBER: {% raw %}${{ github.event.inputs.pr_number }}{% endraw %}
          EXPECTED_HEAD_SHA: {% raw %}${{ github.event.inputs.head_sha }}{% endraw %}
          NEEDS_LABEL: "__NEEDS_LABEL__"
        run: |
          set -euo pipefail

          current_head="$(gh pr view "${PR_NUMBER}" --repo "${GITHUB_REPOSITORY}" --json headRefOid --jq .headRefOid)"
          if [ -n "${EXPECTED_HEAD_SHA:-}" ] && [ "${EXPECTED_HEAD_SHA}" != "${current_head}" ]; then
            echo "::error::PR #${PR_NUMBER} current head ${current_head} does not match expected ${EXPECTED_HEAD_SHA}"
            exit 1
          fi

          gh issue edit "${PR_NUMBER}" --repo "${GITHUB_REPOSITORY}" --add-label "${NEEDS_LABEL}"
          echo "Queued ${NEEDS_LABEL} for ${GITHUB_REPOSITORY}#${PR_NUMBER} at ${current_head}."
