# Code Mower workflow template: manually remove stale or retired audit labels.
name: Code Mower Audit Label Cleanup

on:
  workflow_dispatch:
    inputs:
      pr_number:
        description: "Pull request number"
        required: true
      labels:
        description: "Comma-separated labels to remove"
        required: true

permissions:
  contents: read
  issues: write

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: "true"

jobs:
  cleanup:
    runs-on: ubuntu-latest
    timeout-minutes: 5
    steps:
      - name: Remove requested audit labels
        env:
          GH_TOKEN: {% raw %}${{ secrets.AUDIT_LABEL_CLEANUP_TOKEN || github.token }}{% endraw %}
          PR_NUMBER: {% raw %}${{ github.event.inputs.pr_number }}{% endraw %}
          LABELS: {% raw %}${{ github.event.inputs.labels }}{% endraw %}
        run: |
          set -euo pipefail

          IFS=',' read -r -a labels <<< "${LABELS}"
          for raw_label in "${labels[@]}"; do
            label="$(printf '%s' "${raw_label}" | xargs)"
            [ -n "${label}" ] || continue
            gh issue edit "${PR_NUMBER}" --repo "${GITHUB_REPOSITORY}" --remove-label "${label}" || {
              echo "::notice::Could not remove label ${label}; it may already be absent."
            }
          done
