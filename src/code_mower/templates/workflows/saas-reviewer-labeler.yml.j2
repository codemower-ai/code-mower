# Code Mower workflow template: apply advisory labels from hosted/SaaS reviewer events.
name: __WORKFLOW_NAME__

on:
  issue_comment:
    types: [created, edited]
  issues:
    types: [labeled]
  pull_request_review:
    types: [submitted, edited]
  check_run:
    types: [completed]
  workflow_dispatch:
    inputs:
      adapter:
        description: "SaaS reviewer adapter to classify"
        required: false
        default: "__ADAPTER__"

permissions:
  contents: read
  checks: read
  issues: write
  pull-requests: read

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: "true"

jobs:
  label:
    if: >-
      github.event_name == 'workflow_dispatch' ||
      (
        github.event_name == 'issue_comment' &&
        github.event.issue.pull_request
      ) ||
      (
        github.event_name == 'issues' &&
        github.event.issue.pull_request
      ) ||
      github.event_name == 'pull_request_review' ||
      github.event_name == 'check_run'
    runs-on: ubuntu-latest
    timeout-minutes: 5
    steps:
      - name: Check out Code Mower support files from default branch
        uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10
        with:
          ref: {% raw %}${{ github.event.repository.default_branch }}{% endraw %}
          persist-credentials: false

      - name: Apply __DISPLAY_NAME__ reviewer labels
        env:
          GITHUB_TOKEN: {% raw %}${{ github.token }}{% endraw %}
          __LABEL_TOKEN_ENV__: {% raw %}${{ secrets.__LABEL_TOKEN_ENV__ }}{% endraw %}
          __AUTHORS_ENV__: {% raw %}${{ vars.__AUTHORS_ENV__ }}{% endraw %}
          REVIEWER_ADAPTER: {% raw %}${{ github.event.inputs.adapter || '__ADAPTER__' }}{% endraw %}
        run: tools/code_mower saas-reviewer-labeler --adapter "${REVIEWER_ADAPTER}"
