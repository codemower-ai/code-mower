# Code Mower workflow template: local CLI audit operating note.
#
# Local CLI lanes run in a trusted developer/operator environment so provider
# auth, local checkout paths, and paid model credentials do not cross fork PR
# boundaries inside GitHub Actions.
name: Code Mower Local CLI Audit Note

on:
  workflow_dispatch:
    inputs:
      pr_number:
        description: "Pull request number to audit locally"
        required: true

permissions:
  contents: read

jobs:
  instructions:
    runs-on: ubuntu-latest
    timeout-minutes: 2
    steps:
      - name: Print local audit command shape
        env:
          PR_NUMBER: {% raw %}${{ github.event.inputs.pr_number }}{% endraw %}
        run: |
          cat <<EOF
          Local CLI audit lanes should be run from a trusted checkout, then the
          resulting audit comment should be posted back to PR #${PR_NUMBER}.

          Example command shapes:
            tools/run_codex_audit_pr.sh --repo "${GITHUB_REPOSITORY}" --pr "${PR_NUMBER}"
            tools/run_claude_audit_pr.sh --repo "${GITHUB_REPOSITORY}" --pr "${PR_NUMBER}"
          EOF
